generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum BusinessStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  INVITED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum StockMovementType {
  OPENING_BALANCE
  PURCHASE_IN
  SALE_OUT
  ADJUSTMENT_IN
  ADJUSTMENT_OUT
  RETURN_IN
  RETURN_OUT
  LOSS_OUT
  TRANSFER_IN
  TRANSFER_OUT
}

enum ActivityStatus {
  SUCCESS
  WARNING
  ERROR
}

model Business {
  id                          String                  @id @default(cuid())
  name                        String
  businessName                String?
  phone                       String?
  email                       String?
  location                    String?
  address                     String?
  website                     String?
  poBox                       String?
  fax                         String?
  tin                         String?
  vrn                         String?
  taxId                       String?
  logo                        String?                 @db.Text
  businessDescription         String?                 @db.Text
  receiptFooterMessage        String?                 @db.Text
  businessModule              String                  @default("retail_supermarket")
  subscriptionPlan            String?
  subscriptionBillingCycle    String?
  subscriptionPaymentStatus   String?
  subscriptionStartedAt       DateTime?
  subscriptionEndsAt          DateTime?
  subscriptionTrialEndsAt     DateTime?
  subscriptionDurationDays    Int                     @default(0)
  subscriptionMonths          Int                     @default(0)
  subscriptionDiscountPercent Decimal                 @default(0) @db.Decimal(8, 2)
  subscriptionRawMonthlyPrice Decimal                 @default(0) @db.Decimal(12, 2)
  subscriptionAmountPaid      Decimal                 @default(0) @db.Decimal(12, 2)
  paymentProvider             String?
  paymentPhone                String?
  paymentReference            String?
  status                      BusinessStatus          @default(ACTIVE)
  ownerId                     String?                 @unique
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  owner                       User?                   @relation("BusinessOwner", fields: [ownerId], references: [id])
  customers                   Customer[]
  dashboardSnapshots          DashboardSnapshot[]
  documentCounters            DocumentCounter[]
  expenses                    Expense[]
  logs                        ActivityLog[]
  passwordResetChallenges     PasswordResetChallenge[]
  products                    Product[]
  purchases                   Purchase[]
  roles                       Role[]
  sales                       Sale[]
  sessions                    Session[]
  settings                    BusinessSetting?
  staffProfiles               StaffProfile[]
  stockMovements              StockMovement[]
  subscriptions               SubscriptionRecord[]
  suppliers                   Supplier[]
  users                       User[]                  @relation("BusinessUsers")

  @@index([name])
  @@index([status])
}

model User {
  id                    String               @id @default(cuid())
  businessId            String
  roleId                String?
  employeeId            String?               @unique
  fullName              String
  email                 String?
  phone                 String?
  passwordHash          String
  roleLabel             String?
  profilePhoto          String?              @db.Text
  isOwner               Boolean              @default(false)
  lastLoginAt           DateTime?
  status                UserStatus           @default(ACTIVE)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  business              Business             @relation("BusinessUsers", fields: [businessId], references: [id])
  ownedBusiness         Business?            @relation("BusinessOwner")
  role                  Role?                @relation(fields: [roleId], references: [id])
  createdExpenses       Expense[]            @relation("ExpenseCreatedBy")
  updatedExpenses       Expense[]            @relation("ExpenseUpdatedBy")
  createdLogs           ActivityLog[]        @relation("ActivityActor")
  createdProducts       Product[]            @relation("ProductCreatedBy")
  updatedProducts       Product[]            @relation("ProductUpdatedBy")
  createdPurchases      Purchase[]           @relation("PurchaseCreatedBy")
  updatedPurchases      Purchase[]           @relation("PurchaseUpdatedBy")
  createdSales          Sale[]               @relation("SaleCreatedBy")
  updatedSales          Sale[]               @relation("SaleUpdatedBy")
  passwordResetChallenges PasswordResetChallenge[]
  sessions              Session[]
  staffProfile          StaffProfile?
  stockMovements        StockMovement[]
  subscriptions         SubscriptionRecord[] @relation("SubscriptionCreatedBy")

  @@unique([businessId, employeeId])
  @@index([businessId, roleId])
  @@index([businessId, status])
}

model StaffProfile {
  id             String    @id @default(cuid())
  businessId      String
  userId         String    @unique
  age            Int?
  nationalId     String?
  salaryPerMonth Decimal   @default(0) @db.Decimal(12, 2)
  allowance      Decimal   @default(0) @db.Decimal(12, 2)
  placeFrom      String?
  message        String?   @db.Text
  hiredDate      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  business       Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessId, hiredDate])
}

model Role {
  id          String           @id @default(cuid())
  businessId  String
  name        String
  code        String
  description String?          @db.Text
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  business    Business         @relation(fields: [businessId], references: [id])
  permissions RolePermission[]
  users       User[]

  @@unique([businessId, code])
  @@unique([businessId, name])
  @@index([businessId])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  module      String
  action      String
  description String?          @db.Text
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]

  @@index([module])
}

model RolePermission {
  roleId       String
  permissionId String
  grantedAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Session {
  id             String    @id @default(cuid())
  businessId      String
  userId          String
  refreshTokenHash String
  userAgent       String?
  ipAddress       String?
  expiresAt       DateTime
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  business        Business   @relation(fields: [businessId], references: [id])
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([businessId, userId])
  @@index([expiresAt])
}

model PasswordResetChallenge {
  id          String   @id @default(cuid())
  businessId  String
  userId      String
  phone       String
  otpHash     String
  expiresAt   DateTime
  attemptCount Int     @default(0)
  consumedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  business    Business @relation(fields: [businessId], references: [id])
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, createdAt])
  @@index([userId, expiresAt])
  @@index([expiresAt])
}

model Customer {
  id             String     @id @default(cuid())
  businessId      String
  name           String
  phone          String?
  email          String?
  address        String?
  customerType   String?
  notes          String?    @db.Text
  openingBalance Decimal    @default(0) @db.Decimal(12, 2)
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  business       Business   @relation(fields: [businessId], references: [id])
  sales          Sale[]

  @@index([businessId, name])
  @@index([businessId, isActive])
}

model Supplier {
  id             String      @id @default(cuid())
  businessId      String
  name           String
  contactPerson  String?
  phone          String?
  email          String?
  address        String?
  notes          String?     @db.Text
  openingBalance Decimal     @default(0) @db.Decimal(12, 2)
  inactive       Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  business       Business    @relation(fields: [businessId], references: [id])
  purchases      Purchase[]

  @@index([businessId, name])
  @@index([businessId, inactive])
}

model Product {
  id                 String          @id @default(cuid())
  businessId         String
  createdById        String?
  updatedById        String?
  name               String
  sku                String?
  barcode            String?
  productType        String?
  category           String?
  brand              String?
  unit               String
  sellable           Boolean         @default(true)
  costPrice          Decimal         @default(0) @db.Decimal(12, 2)
  sellingPrice       Decimal         @default(0) @db.Decimal(12, 2)
  stockQuantity      Decimal         @default(0) @db.Decimal(14, 3)
  reorderLevel       Decimal         @default(10) @db.Decimal(14, 3)
  allowNegativeStock Boolean         @default(false)
  trackExpiryDates   Boolean         @default(false)
  trackBatchNumbers  Boolean         @default(false)
  description        String?         @db.Text
  status             ProductStatus   @default(ACTIVE)
  metadata           Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  business           Business        @relation(fields: [businessId], references: [id])
  createdBy          User?           @relation("ProductCreatedBy", fields: [createdById], references: [id])
  updatedBy          User?           @relation("ProductUpdatedBy", fields: [updatedById], references: [id])
  purchaseItems      PurchaseItem[]
  saleItems          SaleItem[]
  stockMovements     StockMovement[]

  @@unique([businessId, sku])
  @@index([businessId, name])
  @@index([businessId, productType])
  @@index([businessId, status])
}

model StockMovement {
  id               String            @id @default(cuid())
  businessId       String
  productId        String
  userId           String?
  movementType     StockMovementType
  referenceType    String?
  referenceId      String?
  quantityDelta    Decimal           @db.Decimal(14, 3)
  unit             String?
  unitCost         Decimal?          @db.Decimal(12, 2)
  unitPrice        Decimal?          @db.Decimal(12, 2)
  notes            String?           @db.Text
  metadata         Json?
  createdAt        DateTime          @default(now())
  business         Business          @relation(fields: [businessId], references: [id])
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  user             User?             @relation(fields: [userId], references: [id])

  @@index([businessId, productId, createdAt])
  @@index([businessId, movementType, createdAt])
  @@index([referenceType, referenceId])
}

model Sale {
  id             String      @id @default(cuid())
  businessId     String
  customerId     String?
  createdById    String?
  updatedById    String?
  saleNumber     String
  invoiceNumber  String?
  poNumber       String?
  customerName   String?
  customerEmail  String?
  customerPhone  String?
  customerAddress String?
  saleType       String?
  paymentMethod  String?
  status         String?
  amount         Decimal     @default(0) @db.Decimal(12, 2)
  subtotal       Decimal     @default(0) @db.Decimal(12, 2)
  tax            Decimal     @default(0) @db.Decimal(12, 2)
  taxRate        Decimal     @default(0) @db.Decimal(8, 2)
  shipping       Decimal     @default(0) @db.Decimal(12, 2)
  discount       Decimal     @default(0) @db.Decimal(12, 2)
  finalTotal     Decimal     @default(0) @db.Decimal(12, 2)
  amountPaid     Decimal     @default(0) @db.Decimal(12, 2)
  balanceDue     Decimal     @default(0) @db.Decimal(12, 2)
  paymentTerms   String?
  dueDate        DateTime?
  saleDate       DateTime
  notes          String?     @db.Text
  description    String?     @db.Text
  metadata       Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  business       Business    @relation(fields: [businessId], references: [id])
  createdBy      User?       @relation("SaleCreatedBy", fields: [createdById], references: [id])
  customer       Customer?   @relation(fields: [customerId], references: [id])
  items          SaleItem[]
  updatedBy      User?       @relation("SaleUpdatedBy", fields: [updatedById], references: [id])

  @@unique([businessId, saleNumber])
  @@index([businessId, saleDate])
  @@index([businessId, customerId])
  @@index([businessId, status])
}

model SaleItem {
  id          String    @id @default(cuid())
  saleId       String
  productId    String?
  item         String
  productType  String?
  productName  String?
  qty          Decimal   @default(0) @db.Decimal(14, 3)
  unit         String?
  price        Decimal   @default(0) @db.Decimal(12, 2)
  total        Decimal   @default(0) @db.Decimal(12, 2)
  metadata     Json?
  createdAt    DateTime  @default(now())
  product      Product?  @relation(fields: [productId], references: [id])
  sale         Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([productId])
}

model Purchase {
  id              String         @id @default(cuid())
  businessId       String
  supplierId      String?
  createdById     String?
  updatedById     String?
  purchaseNumber  String
  supplierName    String?
  supplierPhone   String?
  invoiceNumber   String?
  destination     String?
  status          String?
  paymentStatus   String?
  subtotal        Decimal        @default(0) @db.Decimal(12, 2)
  tax             Decimal        @default(0) @db.Decimal(12, 2)
  discount        Decimal        @default(0) @db.Decimal(12, 2)
  total           Decimal        @default(0) @db.Decimal(12, 2)
  amountPaid      Decimal        @default(0) @db.Decimal(12, 2)
  balanceDue      Decimal        @default(0) @db.Decimal(12, 2)
  purchaseDate    DateTime
  receivedDate    DateTime?
  notes           String?        @db.Text
  metadata        Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  business        Business       @relation(fields: [businessId], references: [id])
  createdBy       User?          @relation("PurchaseCreatedBy", fields: [createdById], references: [id])
  items           PurchaseItem[]
  supplier        Supplier?      @relation(fields: [supplierId], references: [id])
  updatedBy       User?          @relation("PurchaseUpdatedBy", fields: [updatedById], references: [id])

  @@unique([businessId, purchaseNumber])
  @@index([businessId, purchaseDate])
  @@index([businessId, supplierId])
  @@index([businessId, status])
}

model PurchaseItem {
  id          String    @id @default(cuid())
  purchaseId   String
  productId    String?
  itemName     String
  productType  String?
  quantity     Decimal   @default(0) @db.Decimal(14, 3)
  unit         String?
  unitCost     Decimal   @default(0) @db.Decimal(12, 2)
  total        Decimal   @default(0) @db.Decimal(12, 2)
  metadata     Json?
  createdAt    DateTime  @default(now())
  product      Product?  @relation(fields: [productId], references: [id])
  purchase     Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([purchaseId])
  @@index([productId])
}

model Expense {
  id            String    @id @default(cuid())
  businessId     String
  createdById   String?
  updatedById   String?
  title         String
  category      String
  vendor        String?
  paymentMethod String?
  status        String?
  amount        Decimal   @default(0) @db.Decimal(12, 2)
  expenseDate   DateTime
  notes         String?   @db.Text
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  business      Business  @relation(fields: [businessId], references: [id])
  createdBy     User?     @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  updatedBy     User?     @relation("ExpenseUpdatedBy", fields: [updatedById], references: [id])

  @@index([businessId, expenseDate])
  @@index([businessId, category])
  @@index([businessId, status])
}

model ActivityLog {
  id         String         @id @default(cuid())
  businessId  String
  userId     String?
  action     String
  title      String
  details    String?        @db.Text
  entityType String?
  entityId   String?
  status     ActivityStatus @default(SUCCESS)
  metadata   Json?
  createdAt  DateTime       @default(now())
  business   Business       @relation(fields: [businessId], references: [id])
  user       User?          @relation("ActivityActor", fields: [userId], references: [id])

  @@index([businessId, createdAt])
  @@index([businessId, action])
  @@index([entityType, entityId])
}

model BusinessSetting {
  id            String    @id @default(cuid())
  businessId     String    @unique
  general       Json?
  sales         Json?
  inventory     Json?
  notifications Json?
  localization  Json?
  appearance    Json?
  security      Json?
  profile       Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model DocumentCounter {
  id           String   @id @default(cuid())
  businessId    String
  key          String
  prefix       String?
  nextValue    Int      @default(1)
  padding      Int      @default(4)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, key])
}

model SubscriptionRecord {
  id                  String    @id @default(cuid())
  businessId           String
  createdById         String?
  planCode            String
  billingCycle        String
  amountPaid          Decimal   @default(0) @db.Decimal(12, 2)
  rawMonthlyPrice     Decimal   @default(0) @db.Decimal(12, 2)
  discountPercent     Decimal   @default(0) @db.Decimal(8, 2)
  paymentStatus       String
  paymentProvider     String?
  paymentPhone        String?
  paymentReference    String?
  startedAt           DateTime
  endsAt              DateTime?
  trialEndsAt         DateTime?
  durationDays        Int       @default(0)
  months              Int       @default(0)
  metadata            Json?
  createdAt           DateTime  @default(now())
  business            Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy           User?     @relation("SubscriptionCreatedBy", fields: [createdById], references: [id])

  @@index([businessId, createdAt])
  @@index([businessId, paymentStatus])
}

model DashboardSnapshot {
  id                 String    @id @default(cuid())
  businessId          String
  snapshotDate       DateTime
  totalSales         Decimal   @default(0) @db.Decimal(12, 2)
  totalPurchases     Decimal   @default(0) @db.Decimal(12, 2)
  totalExpenses      Decimal   @default(0) @db.Decimal(12, 2)
  netProfit          Decimal   @default(0) @db.Decimal(12, 2)
  lowStockCount      Int       @default(0)
  totalProducts      Int       @default(0)
  totalCustomers     Int       @default(0)
  totalSuppliers     Int       @default(0)
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  business           Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, snapshotDate])
}
